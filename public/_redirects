# Netlify redirects for SPA (Single Page Application)
# This ensures all routes are handled by index.html for client-side routing

# Handle all routes by serving index.html
/*    /index.html   200

# Optional: Handle API calls if you have a backend
# /api/*  https://your-backend-api.com/api/:splat  200

# Optional: Handle specific file types that should not be redirected
# *.js    /assets/:splat  200
